# Copy to ".env" and fill in values. Never commit .env.
# If you pasted an SMTP key in chat or GitHub, revoke it in Brevo and create a new key.

# Who receives forecast emails (staff)
STAFF_EMAIL=ui23ec02@iiitsurat.ac.in

# Brevo SMTP (https://app.brevo.com → SMTP & API)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587

# Login = Brevo SMTP user (ends with @smtp-brevo.com)
SENDER_EMAIL=your-login@smtp-brevo.com

# Secret = Brevo SMTP key (starts with xsmtpsib-...)
SENDER_PASSWORD=

# Optional: "From" header — use a sender verified in Brevo (can differ from login)
SMTP_FROM_EMAIL=your-verified@yourdomain.ac.in

NOTIFICATION_TIME=18:00

# Optional: Gemini API key for LLM features (best-days rewrite, calendar extraction)
GOOGLE_API_KEY=

# Simple admin password for calendar upload/save endpoints
ADMIN_PASSWORD=
